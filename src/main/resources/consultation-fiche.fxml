<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<VBox prefWidth="550" spacing="0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.ConsultationFicheController">
    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <!-- Header Style Impression -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="VITALHEALTH - SYSTÈME MÉDICAL" style="-fx-font-size: 14px; -fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-letter-spacing: 2px;" />
        <Label fx:id="lblTitreFiche" text="FICHE DE CONSULTATION" style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
        <Line endX="470" stroke="#e2e8f0" strokeWidth="2" />
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="30" style="-fx-padding: 30 0 0 0;">
            
            <VBox spacing="20">
                <Label text="INFORMATIONS GÉNÉRALES" style="-fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-font-size: 12px;" />
                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="150" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Référence :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #64748b;" />
                        <Label fx:id="valId" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        
                        <Label fx:id="lblChamp1" text="Champ 1 :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #64748b;" />
                        <Label fx:id="val1" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        
                        <Label fx:id="lblChamp2" text="Champ 2 :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #64748b;" />
                        <Label fx:id="val2" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        
                        <Label fx:id="lblChamp3" text="Champ 3 :" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #64748b;" />
                        <Label fx:id="val3" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                    </children>
                </GridPane>
            </VBox>

            <Separator />

            <VBox spacing="15">
                <Label fx:id="lblChampLong" text="DÉTAILS COMPLÉMENTAIRES" style="-fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-font-size: 12px;" />
                <Label fx:id="valLong" text="Aucun détail supplémentaire disponible." wrapText="true" style="-fx-text-fill: #475569; -fx-line-spacing: 5px; -fx-font-size: 14px;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            
            <VBox alignment="CENTER" spacing="10">
                <Line endX="470" stroke="#f1f5f9" />
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Document généré le :" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                    <Label fx:id="lblDateGeneration" text="25/04/2026" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 20 0 0 0;">
        <Button text="Fermer" onAction="#handleFermer" styleClass="btn-secondary" prefWidth="120" />
        <Button text="Télécharger PDF" onAction="#handleTelechargerPDF" styleClass="btn-primary" prefWidth="180" />
    </HBox>
</VBox>
