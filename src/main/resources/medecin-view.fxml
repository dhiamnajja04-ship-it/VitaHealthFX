<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 0;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.MedecinController">
    
    <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="👨‍⚕️ Liste des Médecins" styleClass="card-title" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10">
                <Button text="+ Nouveau" onAction="#handleNouveau" styleClass="btn-success" />
                <Button text="Modifier" onAction="#handleEditSelected" styleClass="btn-info" />
                <Button text="Supprimer" onAction="#handleSupprimer" styleClass="btn-danger" />
            </HBox>
        </HBox>
        <Separator />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="tfSearch" promptText="Rechercher par nom, prénom ou spécialité..." prefWidth="400" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCount" style="-fx-text-fill: #94a3b8;" />
        </HBox>

        <TableView fx:id="tableMedecin" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colNom" text="Nom" prefWidth="120" />
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120" />
                <TableColumn fx:id="colSpecialite" text="Spécialité" prefWidth="150" />
                <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100" style="-fx-alignment: CENTER;" />
            </columns>
        </TableView>

        <Label fx:id="lblErreur" textFill="#dc3545" style="-fx-font-weight: bold;" />
    </VBox>
</VBox>
