<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 40;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.EventRegistrationController">
    <children>
        <VBox maxWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="Event Registration" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                <Label fx:id="eventTitleLabel" text="Workshop Name" style="-fx-text-fill: #0d9488; -fx-font-weight: bold;" />

                <Separator />

                <VBox spacing="5.0">
                    <Label text="Full Name" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" />
                    <TextField fx:id="nameField" promptText="Enter your name" style="-fx-background-radius: 8; -fx-padding: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Phone Number" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" />
                    <TextField fx:id="phoneField" promptText="+216 ..." style="-fx-background-radius: 8; -fx-padding: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Emergency Contact" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" />
                    <TextField fx:id="emergencyField" promptText="Name / Phone" style="-fx-background-radius: 8; -fx-padding: 10;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Special Notes (Allergies, etc.)" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" />
                    <TextArea fx:id="noteField" prefHeight="80.0" promptText="Any specific requirements..." style="-fx-background-radius: 8; -fx-padding: 10;" wrapText="true" />
                </VBox>

                <HBox spacing="15.0" alignment="CENTER_RIGHT">
                    <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #64748b;" />
                    <Button text="Confirm Registration" onAction="#handleRegister" style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 20; -fx-font-weight: bold; -fx-cursor: hand;" />
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>