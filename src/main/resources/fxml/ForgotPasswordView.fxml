<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" alignment="CENTER" style="-fx-padding: 30; -fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.ForgotPasswordController">
    
    <padding>
        <Insets bottom="25" left="25" right="25" top="25" />
    </padding>

    <!-- TITRE -->
    <Label text="🔐 Mot de passe oublié" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <VBox.margin>
            <Insets bottom="10" />
        </VBox.margin>
    </Label>

    <!-- SOUS-TITRE -->
    <Label text="Récupérez votre compte en 3 étapes" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;">
        <VBox.margin>
            <Insets bottom="10" />
        </VBox.margin>
    </Label>

    <!-- ==================== ÉTAPE 1 : Email + CAPTCHA ==================== -->
    <VBox fx:id="step1Box" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        
        <Label text="📧 Étape 1 : Entrez votre email" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
        
        <TextField fx:id="emailField" promptText="exemple@email.com" style="-fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        
        <Label text="🤖 Étape 2 : Recopiez le code CAPTCHA" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e67e22; -fx-margin-top: 10;" />
        
        <HBox spacing="10" alignment="CENTER">
            <Label fx:id="captchaLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: monospace; -fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 10;" />
            <Button text="🔄" onAction="#refreshCaptcha" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;" />
        </HBox>
        
        <TextField fx:id="captchaField" promptText="Entrez le code ci-dessus" style="-fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        
        <Button fx:id="verifyEmailBtn" text="📧 Vérifier mon email" onAction="#handleVerifyEmail" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <!-- ==================== ÉTAPE 2 : Code de vérification ==================== -->
    <VBox fx:id="step2Box" spacing="15" visible="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        
        <Label text="🔑 Étape 2 : Code de vérification" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" />
        
        <Label text="Un code à 6 chiffres a été envoyé à votre email." wrapText="true" style="-fx-text-fill: #555;" />
        
        <Label text="Entrez le code ci-dessous :" style="-fx-text-fill: #555; -fx-margin-top: 5;" />
        
        <Button text="📧 Vérifier le code" onAction="#handleVerifyCode" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <!-- ==================== ÉTAPE 3 : Nouveau mot de passe ==================== -->
    <VBox fx:id="step3Box" spacing="15" visible="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        
        <Label text="🔒 Étape 3 : Nouveau mot de passe" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
        
        <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe (min 4 caractères)" style="-fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" style="-fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        
        <Button fx:id="resetPasswordBtn" text="✅ Réinitialiser mon mot de passe" onAction="#handleResetPassword" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <!-- MESSAGE D'INFORMATION -->
    <Label fx:id="messageLabel" wrapText="true" style="-fx-text-fill: #333; -fx-font-size: 12px;" />

    <!-- BOUTON RETOUR -->
    <Button text="⬅️ Retour à la connexion" onAction="#handleBackToLogin" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10; -fx-font-size: 13px; -fx-cursor: hand;" />

</VBox>