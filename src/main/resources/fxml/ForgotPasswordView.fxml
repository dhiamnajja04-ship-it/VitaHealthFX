<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER" style="-fx-padding: 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.vitahealthfx.controller.ForgotPasswordController">
    
    <Label text="🔐 Mot de passe oublié" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <TextField fx:id="emailField" promptText="📧 Votre email" style="-fx-padding: 12; -fx-background-radius: 12;"/>
    <Label fx:id="messageLabel" style="-fx-text-fill: #e74c3c;"/>
    <Button text="📧 Envoyer le lien" onAction="#handleSendResetLink" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10;"/>
    <Button text="⬅ Retour" onAction="#handleBackToLogin" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10;"/>
    
</VBox>