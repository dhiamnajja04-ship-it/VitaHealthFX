<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vitahealth.controller.HomeController">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 15 40;">
            <Label style="-fx-text-fill: #27ae60; -fx-font-size: 20px; -fx-font-weight: bold;" text="🏥 VitaHealthFX" HBox.hgrow="ALWAYS" />
            <Button fx:id="loginBtn" style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-border-color: #27ae60; -fx-border-radius: 25; -fx-padding: 8 25; -fx-cursor: hand;" text="Connexion" />
            <Button fx:id="registerBtn" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 8 25; -fx-cursor: hand;" text="Inscription" />
        </HBox>
    </top>

    <!-- Hero Section -->
    <center>
        <VBox alignment="CENTER" spacing="30.0" style="-fx-padding: 60;">
            <Label style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #1a2a3a;" text="Prenez soin de votre santé" />
            <Label style="-fx-font-size: 18px; -fx-text-fill: #7f8c8d;" text="La plateforme médicale connectée qui vous accompagne au quotidien" />
            <Button fx:id="getStartedBtn" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 12 40; -fx-cursor: hand;" text="🚀 Commencer" />

            <GridPane hgap="30.0" vgap="30.0" alignment="CENTER" style="-fx-padding: 40 0 0 0;">
                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 5);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 40px;" text="🏥" />
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Télémédecine" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-text-alignment: center;" text="Consultez des médecins à distance" />
                </VBox>

                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 5);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 40px;" text="📅" />
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Rendez-vous" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-text-alignment: center;" text="Prenez RDV facilement" />
                </VBox>

                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 5);" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 40px;" text="📊" />
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Suivi Santé" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-text-alignment: center;" text="Suivez vos paramètres" />
                </VBox>
            </GridPane>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 20;" spacing="30.0">
            <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="© 2024 VitaHealthFX" />
            <Label style="-fx-text-fill: #7f8c8d;" text="|" />
            <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="support@vitahealth.com" />
            <Label style="-fx-text-fill: #7f8c8d;" text="|" />
            <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="📞 +216 00 000 000" />
        </HBox>
    </bottom>
</BorderPane>