<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.ForumModerationController">
    <top>
        <VBox spacing="10.0" style="-fx-padding: 20 24 10 24;">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox>
                    <Label text="Moderation du Forum" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                    <Label text="Validez les contenus sensibles, traitez les signalements et gardez le forum sain." style="-fx-text-fill: #64748b;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="refreshBtn" text="Actualiser" styleClass="btn-secondary" />
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.55" style="-fx-background-color: transparent;">
            <items>
                <VBox spacing="10.0" style="-fx-padding: 0 12 20 24;">
                    <TableView fx:id="moderationTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTitle" text="Titre" prefWidth="230" />
                            <TableColumn fx:id="colCategory" text="Categorie" prefWidth="120" />
                            <TableColumn fx:id="colAuthor" text="Auteur" prefWidth="130" />
                            <TableColumn fx:id="colStatus" text="Statut" prefWidth="115" />
                            <TableColumn fx:id="colReports" text="Signalements" prefWidth="95" />
                            <TableColumn fx:id="colDate" text="Date" prefWidth="130" />
                        </columns>
                    </TableView>
                    <Label fx:id="messageLabel" text="" style="-fx-text-fill: #475569;" />
                </VBox>

                <VBox spacing="12.0" style="-fx-padding: 0 24 20 12;">
                    <Label text="Detail publication" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                    <Label fx:id="metaLabel" text="" wrapText="true" style="-fx-text-fill: #64748b;" />
                    <TextArea fx:id="contentArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />
                    <HBox spacing="10.0">
                        <Button fx:id="publishBtn" text="Publier" styleClass="btn-primary" />
                        <Button fx:id="hideBtn" text="Masquer" styleClass="btn-secondary" />
                        <Button fx:id="lockBtn" text="Verrouiller" styleClass="btn-outline" />
                        <Button fx:id="deleteBtn" text="Supprimer" styleClass="btn-danger" />
                    </HBox>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
