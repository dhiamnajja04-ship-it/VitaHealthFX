<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="20.0" style="-fx-background-color: #f4f4f4;" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.LoginController">
    <children>
        <Label text="VitaHealth Login" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label text="Email" />
                <TextField fx:id="emailField" promptText="Enter your email" style="-fx-background-radius: 5;" />
            </children>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label text="Password" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-background-radius: 5;" />
            </children>
        </VBox>
        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5;" text="Login">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </children>
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
</VBox>