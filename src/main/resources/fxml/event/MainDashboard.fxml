<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.MainDashboardController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 30 0 30; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="VITA" textFill="#0d9488"><font><Font name="System Bold" size="22.0" /></font></Label>
                <Label text="HEALTH" textFill="#1e293b"><font><Font name="System Bold" size="22.0" /></font><HBox.margin><Insets left="-18.0" /></HBox.margin></Label>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button onAction="#showUserDashboard" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand;" text="Dashboard" />
                        <Button onAction="#showUserEventView" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand;" text="Explore Events" />
                        <Separator orientation="VERTICAL" />
                        <Button fx:id="adminPanelBtn" onAction="#toggleAdminMode" style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-font-weight: bold;" text="Admin Panel" />
                    </children>
                </HBox>
                <Separator orientation="VERTICAL" prefHeight="30.0" />
                <Label fx:id="userNameLabel" text="User" textFill="#1e293b" style="-fx-font-weight: bold;" />
            </children>
        </HBox>

        <BorderPane fx:id="mainPane" VBox.vgrow="ALWAYS">
            <left>
                <VBox fx:id="sidebar" managed="false" visible="false" prefWidth="260.0" spacing="8.0" style="-fx-background-color: #1e293b;">
                    <padding><Insets bottom="20.0" left="15.0" right="15.0" top="30.0" /></padding>
                    <children>
                        <Label text="ADMINISTRATION" textFill="#64748b" style="-fx-font-weight: bold; -fx-font-size: 11;" />
                        <Button maxWidth="Infinity" onAction="#showAdminEvents" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 12;" text="⚙️  Manage Events" />
                        <Button maxWidth="Infinity" onAction="#showAdminParticipations" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-alignment: center-left; -fx-padding: 12;" text="🤝  Participations" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #ef444422; -fx-text-fill: #ef4444;" text="Sign Out" />
                    </children>
                </VBox>
            </left>
            <center>
                <StackPane fx:id="contentArea" style="-fx-background-color: #f0f9ff;" />
            </center>
        </BorderPane>
    </children>
</VBox>