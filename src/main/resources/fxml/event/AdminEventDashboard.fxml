<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="750.0" prefWidth="1200.0" spacing="25.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.AdminEventController">
    <children>
        <VBox prefWidth="400.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
            <children>
                <Label text="Workshop Details" textFill="#0f172a">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Label text="Fill in the information to manage your event." textFill="#64748b" wrapText="true" />

                <Separator />

                <Label text="Title" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="titleField" promptText="Enter event title" style="-fx-background-radius: 8; -fx-padding: 8;" />

                <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextArea fx:id="descField" prefHeight="80.0" promptText="Describe the workshop..." style="-fx-background-radius: 8;" wrapText="true" />

                <Label text="Date &amp; Time" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <DatePicker fx:id="datePicker" maxWidth="Infinity" style="-fx-background-radius: 8;" />

                <VBox spacing="8.0" style="-fx-padding: 5 0;">
                    <Label text="Location" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />

                    <Button onAction="#openMapPicker" maxWidth="Infinity"
                            style="-fx-background-color: #f8fafc; -fx-border-color: #0ea5e9; -fx-border-radius: 8; -fx-padding: 15; -fx-cursor: hand; -fx-text-fill: #0ea5e9; -fx-font-weight: bold;"
                            text="📍 Open Map to Select Location" />

                    <HBox spacing="10.0">
                        <children>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="Latitude" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                <TextField fx:id="latField" editable="false" promptText="0.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 5;" />
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="Longitude" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                <TextField fx:id="lngField" editable="false" promptText="0.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 5;" />
                            </VBox>
                        </children>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="10.0">
                    <HBox spacing="10.0">
                        <Button onAction="#handleAdd" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;" text="Add Workshop" />
                        <Button onAction="#handleClear" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10; -fx-cursor: hand;" text="↺" />
                    </HBox>
                    <Button onAction="#handleUpdate" maxWidth="Infinity" style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;" text="Update Workshop" />
                    <Button onAction="#handleDelete" maxWidth="Infinity" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete Permanently" />
                </VBox>
            </children>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <TextField fx:id="searchBar" HBox.hgrow="ALWAYS" promptText="🔍 Search by title or description..." style="-fx-background-radius: 25; -fx-padding: 12; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="eventContainer" spacing="15.0" style="-fx-padding: 5; -fx-background-color: transparent;" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</HBox>