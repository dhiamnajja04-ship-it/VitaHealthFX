<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="500.0" style="-fx-background-color: linear-gradient(135deg, #667eea, #764ba2);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.workshopjdbc.Controllers.LoginController">

    <children>
        <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 30px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
            <padding>
                <Insets bottom="40.0" left="30.0" right="30.0" top="40.0" />
            </padding>

            <VBox alignment="CENTER" spacing="10.0">
                <Label style="-fx-font-size: 50px;" text="🏥" />
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="VitaHealthFX" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" text="Plateforme Médicale Connectée" />
            </VBox>

            <Separator prefWidth="300.0" />

            <VBox spacing="20.0">
                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📧 Adresse email" />
                    <TextField fx:id="emailField" promptText="exemple@email.com" style="-fx-background-color: #f8f9fa; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🔒 Mot de passe" />
                    <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-background-color: #f8f9fa; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12;" />
                </VBox>

                <Label fx:id="messageLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" text="" wrapText="true" />

                <Button fx:id="loginBtn" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12; -fx-cursor: hand;" text="🔑 SE CONNECTER" />

                <HBox alignment="CENTER" spacing="10.0">
                    <Label style="-fx-text-fill: #7f8c8d;" text="Pas encore de compte ?" />
                    <Hyperlink fx:id="registerLink" style="-fx-text-fill: #3498db; -fx-font-size: 13px; -fx-cursor: hand; -fx-font-weight: bold;" text="S'inscrire" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>