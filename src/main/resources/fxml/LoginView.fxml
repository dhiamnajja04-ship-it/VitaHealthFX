<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="550.0" prefWidth="450.0" style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vitahealth.controller.LoginController">

    <children>
        <!-- Carte Glassmorphism -->
        <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 30px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="35.0" AnchorPane.rightAnchor="35.0" AnchorPane.topAnchor="50.0">
            <padding>
                <Insets bottom="40.0" left="30.0" right="30.0" top="40.0" />
            </padding>

            <!-- Logo et Titre -->
            <VBox alignment="CENTER" spacing="10.0">
                <Label style="-fx-font-size: 50px;" text="🏥" />
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="VitaHealthFX" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" text="Plateforme Médicale Connectée" />
            </VBox>

            <Separator prefWidth="300.0" />

            <!-- Formulaire -->
            <VBox spacing="20.0">

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📧 Adresse email" />
                    <TextField fx:id="emailField" promptText="exemple@email.com" style="-fx-background-color: #f8f9fa; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🔒 Mot de passe" />
                    <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-background-color: #f8f9fa; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12;" />
                </VBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" text="" wrapText="true" />

                <Button fx:id="loginButton" style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12;" text="🔑 SE CONNECTER" />

                <HBox alignment="CENTER" spacing="10.0">
                    <Label style="-fx-text-fill: #7f8c8d;" text="Pas encore de compte ?" />
                    <Button fx:id="registerButton" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-underline: true; -fx-cursor: hand; -fx-font-weight: bold;" text="S'inscrire" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>