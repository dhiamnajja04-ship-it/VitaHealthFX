<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="750.0" prefWidth="1300.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 15 25;">
            <Label style="-fx-text-fill: #27ae60; -fx-font-size: 22px; -fx-font-weight: bold;" text="🏥 VitaHealthFX" />
            <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="Administration" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="userLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;" text="Admin" />
            <Button fx:id="logoutBtn" onAction="#logout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" text="🚪 Déconnexion" />
        </HBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" style="-fx-background-color: white; -fx-tab-min-height: 40; -fx-tab-max-height: 40;" tabClosingPolicy="UNAVAILABLE">

            <Tab text="📊 Dashboard">
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox spacing="25.0" style="-fx-padding: 25;">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Tableau de bord" />

                        <GridPane hgap="20.0" vgap="20.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                            </columnConstraints>
                            <children>
                                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #667eea; -fx-padding: 25; -fx-background-radius: 15;" GridPane.columnIndex="0">
                                    <Label fx:id="totalUsersLabel" style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;" text="0" />
                                    <Label style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;" text="👥 Total Utilisateurs" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #27ae60; -fx-padding: 25; -fx-background-radius: 15;" GridPane.columnIndex="1">
                                    <Label fx:id="totalPatientsLabel" style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;" text="0" />
                                    <Label style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;" text="👤 Patients" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #3498db; -fx-padding: 25; -fx-background-radius: 15;" GridPane.columnIndex="2">
                                    <Label fx:id="totalDoctorsLabel" style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;" text="0" />
                                    <Label style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;" text="👨‍⚕️ Médecins" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #f39c12; -fx-padding: 25; -fx-background-radius: 15;" GridPane.columnIndex="3">
                                    <Label fx:id="totalAppointmentsLabel" style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;" text="0" />
                                    <Label style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;" text="📅 Rendez-vous" />
                                </VBox>
                            </children>
                        </GridPane>

                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="📈 Activité récente" />
                        <HBox spacing="20.0">
                            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="👥 Nouveaux utilisateurs (30j)" />
                                <Label fx:id="newUsersLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0" />
                            </VBox>
                            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📅 Rendez-vous ce mois" />
                                <Label fx:id="monthAppointmentsLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                            </VBox>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab text="👥 Utilisateurs">
                <VBox spacing="15.0" style="-fx-padding: 20;">
                    <HBox spacing="15.0">
                        <TextField fx:id="searchField" promptText="🔍 Rechercher..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 25; -fx-padding: 10 15;" />
                        <Button onAction="#loadAllUsers" text="Rechercher" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 25;" />
                        <Button onAction="#openAddUserDialog" text="➕ Nouveau" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 25;" />
                        <Button onAction="#refreshAll" text="🔄 Rafraîchir" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 25;" />
                    </HBox>

                    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="250" />
                            <TableColumn fx:id="colFirstName" text="Prénom" prefWidth="150" />
                            <TableColumn fx:id="colLastName" text="Nom" prefWidth="150" />
                            <TableColumn fx:id="colRole" text="Rôle" prefWidth="100" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="📅 Rendez-vous">
                <VBox spacing="15.0" style="-fx-padding: 20;">
                    <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS" />
                </VBox>
            </Tab>

            <Tab text="🎭 Ateliers/Events">
                <fx:include source="event/AdminEventDashboard.fxml" />
            </Tab>

            <Tab text="🤝 Participations">
                <fx:include source="event/AdminParticipation.fxml" />
            </Tab>

            <Tab text="📈 Statistiques">
                <fx:include source="event/StatsView.fxml" />
            </Tab>

        </TabPane>
    </center>
</BorderPane>