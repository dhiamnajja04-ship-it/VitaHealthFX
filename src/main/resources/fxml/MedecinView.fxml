<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vitahealth.controller.DoctorController">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 15 25;">
                <Label style="-fx-text-fill: #27ae60; -fx-font-size: 22px; -fx-font-weight: bold;" text="VitaHealthFX" />
                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="Espace Medecin" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="userLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;" text="Medecin" />
                <Button fx:id="logoutBtn" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" text="Deconnexion" />
            </HBox>

            <TabPane>
                <!-- TAB 1: MON AGENDA -->
                <Tab text="Mon Agenda" closable="false">
                    <VBox spacing="15.0" style="-fx-padding: 20;">
                        <HBox spacing="15.0">
                            <DatePicker fx:id="dateFilter" promptText="Filtrer par date" />
                            <Button fx:id="clearFilterBtn" text="Effacer filtre" />
                            <Button fx:id="refreshBtn" text="Rafraichir" />
                        </HBox>

                        <TableView fx:id="appointmentsTable" prefHeight="580.0">
                            <columns>
                                <TableColumn fx:id="colTime" text="Heure" prefWidth="100" />
                                <TableColumn fx:id="colPatient" text="Patient" prefWidth="250" />
                                <TableColumn fx:id="colReason" text="Motif" prefWidth="350" />
                                <TableColumn fx:id="colStatus" text="Statut" prefWidth="120" />
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 2: MES PATIENTS -->
                <Tab text="Mes Patients" closable="false">
                    <VBox spacing="15.0" style="-fx-padding: 20;">
                        <TextField fx:id="searchPatientField" promptText="Rechercher un patient..." />

                        <TableView fx:id="patientsTable" prefHeight="580.0">
                            <columns>
                                <TableColumn fx:id="patColName" text="Nom du patient" prefWidth="250" />
                                <TableColumn fx:id="patColEmail" text="Email" prefWidth="300" />
                                <TableColumn fx:id="patColLastAppointment" text="Dernier RDV" prefWidth="200" />
                                <TableColumn fx:id="patColActions" text="Actions" prefWidth="150" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 3: PRESCRIPTIONS -->
                <Tab text="Prescriptions" closable="false">
                    <VBox spacing="15" style="-fx-padding: 20;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Patient :" style="-fx-font-weight: bold;" />
                            <ComboBox fx:id="patientPrescCombo" prefWidth="300" promptText="Choisir un patient" />
                            <Button fx:id="loadPatientPrescBtn" text="Charger" />
                            <Button fx:id="refreshPrescListBtn" text="Rafraichir" />
                        </HBox>

                        <Separator />

                        <GridPane hgap="15" vgap="10">
                            <Label style="-fx-font-weight: bold;" text="Medicaments :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextArea fx:id="medicamentsArea" prefHeight="80" prefWidth="400" promptText="Ex: Paracetamol 500mg&#10;Amoxicilline 1g" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <Label style="-fx-font-weight: bold;" text="Duree :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <TextField fx:id="dureeField" promptText="ex: 7 jours" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <Label style="-fx-font-weight: bold;" text="Instructions :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <TextArea fx:id="instructionsArea" prefHeight="60" promptText="Prendre matin et soir apres les repas" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        </GridPane>

                        <HBox alignment="CENTER" spacing="10">
                            <Button fx:id="ajouterPrescriptionBtn" text="Ajouter" />
                            <Button fx:id="modifierPrescriptionBtn" text="Modifier" />
                            <Button fx:id="supprimerPrescriptionBtn" text="Supprimer" />
                            <Button fx:id="viderPrescChampsBtn" text="Vider" />
                        </HBox>

                        <TableView fx:id="prescriptionTable" prefHeight="300">
                            <columns>
                                <TableColumn fx:id="colPrescDate" text="Date" prefWidth="150" />
                                <TableColumn fx:id="colMedicaments" text="Medicaments" prefWidth="300" />
                                <TableColumn fx:id="colDuree" text="Duree" prefWidth="120" />
                                <TableColumn fx:id="colInstructions" text="Instructions" prefWidth="350" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 4: PARAMETRES MEDICAUX -->
                <Tab text="Parametres medicaux" closable="false">
                    <VBox spacing="15" style="-fx-padding: 20;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Patient :" style="-fx-font-weight: bold;" />
                            <ComboBox fx:id="patientParamCombo" prefWidth="300" promptText="Choisir un patient" />
                            <Button fx:id="loadPatientParamBtn" text="Charger" />
                            <Button fx:id="refreshParamListBtn" text="Rafraichir" />
                        </HBox>

                        <Separator />

                        <Label text="Historique des parametres medicaux" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                        <TableView fx:id="parametreTable" prefHeight="500">
                            <columns>
                                <TableColumn fx:id="colParamDate" text="Date" prefWidth="150" />
                                <TableColumn fx:id="colPoids" text="Poids (kg)" prefWidth="100" />
                                <TableColumn fx:id="colTaille" text="Taille (m)" prefWidth="100" />
                                <TableColumn fx:id="colGlycemie" text="Glycemie" prefWidth="100" />
                                <TableColumn fx:id="colTension" text="Tension" prefWidth="100" />
                                <TableColumn fx:id="colImc" text="IMC" prefWidth="80" />
                                <TableColumn fx:id="colInterpretation" text="Interpretation" prefWidth="200" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </top>
</BorderPane>