<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.vitahealth.controller.RegisterController"
           style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e);">

    <VBox alignment="CENTER" spacing="15" maxWidth="400"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40;">
        <Text text="📝 Inscription" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #2c3e66;" />

        <TextField fx:id="firstNameField" promptText="Prénom" style="-fx-padding: 12; -fx-background-radius: 10;" />
        <TextField fx:id="lastNameField" promptText="Nom" style="-fx-padding: 12; -fx-background-radius: 10;" />
        <TextField fx:id="emailField" promptText="Email" style="-fx-padding: 12; -fx-background-radius: 10;" />
        <PasswordField fx:id="passwordField" promptText="Mot de passe" style="-fx-padding: 12; -fx-background-radius: 10;" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer mot de passe" style="-fx-padding: 12; -fx-background-radius: 10;" />

        <HBox spacing="20" alignment="CENTER">
            <RadioButton fx:id="patientRadio" text="Patient" selected="true">
                <toggleGroup>
                    <ToggleGroup fx:id="roleGroup" />
                </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="doctorRadio" text="Médecin" toggleGroup="$roleGroup" />
        </HBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" />
        <Label fx:id="successLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 12px;" />

        <Button fx:id="registerButton" text="S'INSCRIRE"
                style="-fx-background-color: #2c3e66; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 25;"
                maxWidth="Infinity" />

        <Button fx:id="loginButton" text="🔑 Déjà un compte ? Se connecter"
                style="-fx-background-color: transparent; -fx-text-fill: #2c3e66; -fx-underline: true;"
                maxWidth="Infinity" />
    </VBox>
</StackPane>