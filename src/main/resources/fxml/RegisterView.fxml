<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="450.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vitahealth.controller.RegisterController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 40;">
                    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="CREER UN COMPTE" />
                    <Separator prefWidth="350.0" />
                    <VBox spacing="15.0" maxWidth="350.0">
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Prenom" />
                            <TextField fx:id="firstNameField" promptText="Votre prenom" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Nom" />
                            <TextField fx:id="lastNameField" promptText="Votre nom" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Email" />
                            <TextField fx:id="emailField" promptText="exemple@email.com" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Mot de passe" />
                            <PasswordField fx:id="passwordField" promptText="********" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Confirmer mot de passe" />
                            <PasswordField fx:id="confirmPasswordField" promptText="********" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label style="-fx-font-weight: bold;" text="Vous etes :" />
                            <HBox spacing="20.0">
                                <RadioButton fx:id="patientRadio" selected="true" text="Patient">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="roleGroup" />
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton fx:id="doctorRadio" text="Medecin" toggleGroup="$roleGroup" />
                            </HBox>
                        </VBox>
                        <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" text="" wrapText="true" />
                        <Label fx:id="successLabel" style="-fx-text-fill: green; -fx-font-size: 12px;" text="" wrapText="true" />
                        <Button fx:id="registerButton" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10; -fx-cursor: hand;" text="S'INSCRIRE" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <Label style="-fx-text-fill: #7f8c8d;" text="Deja un compte ?" />
                            <Button fx:id="loginButton" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-underline: true; -fx-cursor: hand;" text="Se connecter" />
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>