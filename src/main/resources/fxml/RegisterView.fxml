<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="800.0" prefWidth="650.0" style="-fx-background-color: linear-gradient(135deg, #667eea, #764ba2);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.vitahealthfx.controller.RegisterController">

    <children>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 30px;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

            <Text text="📝 Créer un compte" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #2c3e50;" />

            <GridPane hgap="15" vgap="12">
                <Label text="Prénom :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="firstNameField" promptText="Jean" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Nom :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="lastNameField" promptText="Dupont" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Email :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="emailField" promptText="exemple@email.com" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Téléphone :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="phoneField" promptText="+216 00 000 000" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Mot de passe :" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Confirmer :" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="••••••••" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-padding: 10; -fx-background-radius: 10;"/>

                <Label text="Rôle :" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="roleCombo" GridPane.rowIndex="6" GridPane.columnIndex="1" style="-fx-padding: 8;" value="PATIENT"/>
            </GridPane>

            <!-- Captcha -->
            <HBox spacing="10.0" alignment="CENTER">
                <TextField fx:id="captchaField" promptText="Code captcha" prefWidth="120" style="-fx-padding: 8; -fx-background-radius: 10;"/>
                <Label fx:id="captchaLabel" style="-fx-background-color: #ecf0f1; -fx-padding: 8 15; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                <Button text="⟳" onAction="#refreshCaptcha" style="-fx-background-color: #bdc3c7; -fx-background-radius: 20; -fx-cursor: hand;"/>
            </HBox>

            <!-- I'm not a robot -->
            <CheckBox fx:id="robotCheckBox" text="🤖 I'm not a robot" style="-fx-padding: 5; -fx-font-weight: bold;"/>

            <Label fx:id="messageLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" wrapText="true" />

            <Button fx:id="registerBtn" onAction="#handleRegister" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12; -fx-cursor: hand;" text="✅ S'INSCRIRE" />

            <HBox alignment="CENTER" spacing="5.0">
                <Label style="-fx-text-fill: #7f8c8d;" text="Déjà un compte ?" />
                <Hyperlink onAction="#openLogin" style="-fx-text-fill: #3498db; -fx-cursor: hand;" text="Se connecter" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>