<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="controllers.MainController" prefHeight="750.0" prefWidth="1100.0">
    
    <!-- Top Header -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20" prefHeight="70">
            <VBox alignment="CENTER_LEFT">
                <Label text="VitalHealth" styleClass="logo-text" />
                <Label text="SYSTÈME DE GESTION MÉDICALE" style="-fx-font-size: 9px; -fx-text-fill: #94a3b8; -fx-font-weight: 800; -fx-letter-spacing: 1.5px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER">
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-padding: 8 15; -fx-background-radius: 20;">
                    <Circle radius="5" fill="#10b981"/>
                    <Label text="Serveur Connecté" style="-fx-font-size: 11px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                </HBox>
                <Button text="🔔" styleClass="btn-secondary" style="-fx-background-radius: 20; -fx-min-width: 40; -fx-min-height: 40;"/>
                <Separator orientation="VERTICAL" />
                <HBox spacing="10" alignment="CENTER">
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Dr. Jihed" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #1e293b;"/>
                        <Label text="Administrateur" style="-fx-font-size: 10px; -fx-text-fill: #6366f1; -fx-font-weight: bold;"/>
                    </VBox>
                    <Circle radius="20" fill="#e2e8f0" stroke="#6366f1" strokeWidth="2"/>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- Sidebar Navigation -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="10">
            <Label text="NAVIGATION PRINCIPALE" styleClass="sidebar-category" />
            <Button text="📊 Tableau de Bord" fx:id="btnRdv" onAction="#showRendezVous" styleClass="sidebar-btn, sidebar-btn-active" />
            
            <Label text="ADMINISTRATION" styleClass="sidebar-category" />
            <Button text="👥 Liste des Médecins" fx:id="btnMedecins" onAction="#showMedecins" styleClass="sidebar-btn" />
            <Button text="📜 Historique RDV" fx:id="btnReponses" onAction="#showReponses" styleClass="sidebar-btn" />
            
            <Label text="ESPACE PRATICIEN" styleClass="sidebar-category" />
            <Button text="🏥 Mon Espace" fx:id="btnEspaceMedecin" onAction="#showEspaceMedecin" styleClass="sidebar-btn" />
            
            <Region VBox.vgrow="ALWAYS" />
            <VBox spacing="5" style="-fx-padding: 0 10 20 10;">
                <Button text="⚙ Paramètres" styleClass="sidebar-btn" style="-fx-min-width: 210;"/>
                <Button text="🚪 Déconnexion" styleClass="sidebar-btn" style="-fx-text-fill: #f87171; -fx-min-width: 210;"/>
            </VBox>
        </VBox>
    </left>

    <!-- Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #f1f5f9); -fx-padding: 30;">
            <children>
                <!-- Decorative Background Element -->
                <Pane mouseTransparent="true" opacity="0.4">
                    <children>
                        <Circle radius="150" fill="#6366f1" layoutX="800" layoutY="100" opacity="0.05" />
                        <Circle radius="100" fill="#d946ef" layoutX="100" layoutY="600" opacity="0.05" />
                    </children>
                </Pane>
                <!-- Content Injected Dynamically -->
            </children>
        </StackPane>
    </center>
</BorderPane>

