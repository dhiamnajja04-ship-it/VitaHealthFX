<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" style="-fx-padding: 5;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.RendezVousController">
    
    <!-- Dashboard Stats Header -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Total Rendez-vous" styleClass="stat-label" />
            <Label fx:id="lblTotalRdv" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Cas Urgents" styleClass="stat-label" />
            <Label fx:id="lblUrgentRdv" text="--" styleClass="stat-value" style="-fx-text-fill: #ef4444;" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Aujourd'hui" styleClass="stat-label" />
            <Label fx:id="lblTodayRdv" text="--" styleClass="stat-value" style="-fx-text-fill: #10b981;" />
        </VBox>
    </HBox>

    <VBox spacing="20" styleClass="card" VBox.vgrow="ALWAYS">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox>
                <Label text="Liste des Consultations" styleClass="card-title" style="-fx-padding: 0;"/>
                <Label text="Gérez les rendez-vous et le flux des patients en temps réel." style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="12">
                <Button text="+ Nouveau RDV" onAction="#handleNouveau" styleClass="btn-primary" prefHeight="40">
                    <graphic>
                        <Label text="➕" style="-fx-text-fill: white;"/>
                    </graphic>
                </Button>
                <Button text="Modifier" onAction="#handleEditSelected" styleClass="btn-secondary" prefHeight="40" />
                <Button text="Supprimer" onAction="#handleSupprimer" styleClass="btn-danger" prefHeight="40" />
            </HBox>
        </HBox>

        <Separator />

        <!-- Barre de Recherche et Filtres -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="tfSearch" promptText="Rechercher un patient ou un motif..." prefWidth="350" styleClass="search-field" />
            <ComboBox fx:id="cbFiltrePriorite" promptText="Filtrer par Priorité" prefWidth="180" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCount" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500;" />
        </HBox>

        <VBox VBox.vgrow="ALWAYS" spacing="10">
            <TableView fx:id="tableRdv" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="Aucun rendez-vous enregistré." style="-fx-text-fill: #94a3b8;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="colDate" text="DATE" prefWidth="100" />
                    <TableColumn fx:id="colHeure" text="HEURE" prefWidth="80" />
                    <TableColumn fx:id="colPatientNom" text="PATIENT" prefWidth="150" />
                    <TableColumn fx:id="colMotif" text="MOTIF" prefWidth="200" />
                    <TableColumn fx:id="colPriorite" text="PRIORITÉ" prefWidth="110" />
                    <TableColumn fx:id="colMedecinId" text="MÉDECIN" prefWidth="100" />
                    <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="100" style="-fx-alignment: CENTER;" />
                </columns>
            </TableView>
            
            <HBox alignment="CENTER" spacing="10">
                <Pagination fx:id="pagination" maxPageIndicatorCount="5" />
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT">
            <Label fx:id="lblErreur" wrapText="true" style="-fx-font-weight: bold;" />
        </HBox>
    </VBox>
</VBox>
