<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RendezVousController"
      style="-fx-padding: 0;">

    <!-- Stats Row -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="📅  Total RDV"   styleClass="stat-label"/>
            <Label fx:id="lblTotalRdv"  text="—" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="🚨  Urgences"   styleClass="stat-label"/>
            <Label fx:id="lblUrgentRdv" text="—" styleClass="stat-value" style="-fx-text-fill:#ef4444;"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="☀️  Aujourd'hui" styleClass="stat-label"/>
            <Label fx:id="lblTodayRdv"  text="—" styleClass="stat-value" style="-fx-text-fill:#10b981;"/>
        </VBox>
    </HBox>

    <!-- Main Card -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="16">

        <!-- Toolbar -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <VBox>
                <Label text="Gestion des Rendez-vous" styleClass="card-title" style="-fx-padding:0;"/>
                <Label text="Consultez et gérez en temps réel le flux des patients."
                       style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10">
                <Button text="➕  Nouveau RDV" onAction="#handleNouveau"      styleClass="btn-primary"   prefHeight="38"/>
                <Button text="✏  Modifier"     onAction="#handleEditSelected" styleClass="btn-secondary" prefHeight="38"/>
                <Button text="🗑  Supprimer"   onAction="#handleSupprimer"    styleClass="btn-danger"    prefHeight="38"/>
            </HBox>
        </HBox>

        <Separator/>

        <!-- Search + Filter -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="tfSearch" promptText="🔍  Rechercher patient ou motif…"
                       prefWidth="320" styleClass="search-field"/>
            <ComboBox fx:id="cbFiltrePriorite" prefWidth="170"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCount" style="-fx-text-fill:#94a3b8; -fx-font-weight:600;"/>
        </HBox>

        <!-- Table — fills remaining vertical space -->
        <TableView fx:id="tableRdv" VBox.vgrow="ALWAYS" minHeight="300">
            <placeholder>
                <Label text="Aucun rendez-vous enregistré." style="-fx-text-fill:#94a3b8;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colId"        text="ID"       prefWidth="50"  minWidth="40"/>
                <TableColumn fx:id="colDate"       text="DATE"     prefWidth="105" minWidth="90"/>
                <TableColumn fx:id="colHeure"      text="HEURE"    prefWidth="80"  minWidth="70"/>
                <TableColumn fx:id="colPatientNom" text="PATIENT"  prefWidth="160" minWidth="120"/>
                <TableColumn fx:id="colMotif"      text="MOTIF"    prefWidth="200" minWidth="140"/>
                <TableColumn fx:id="colPriorite"   text="PRIORITÉ" prefWidth="115" minWidth="90"/>
                <TableColumn fx:id="colMedecinId"  text="MÉDECIN"  prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colActions"    text="ACTIONS"  prefWidth="100" minWidth="80"
                             style="-fx-alignment:CENTER;"/>
            </columns>
        </TableView>

        <!-- Custom Pagination Bar (OUTSIDE the table, no overlap) -->
        <HBox alignment="CENTER" spacing="10" style="-fx-padding:4 0 0 0;">
            <Button fx:id="btnPrevPage" text="‹  Préc." onAction="#handlePrevPage"
                    styleClass="page-btn" prefWidth="90" prefHeight="34"/>
            <Label fx:id="lblPageInfo" text="Page 1 / 1"
                   style="-fx-font-size:13px; -fx-font-weight:700; -fx-text-fill:#475569; -fx-padding:0 12;"/>
            <Button fx:id="btnNextPage" text="Suiv.  ›" onAction="#handleNextPage"
                    styleClass="page-btn" prefWidth="90" prefHeight="34"/>
        </HBox>

        <!-- Status label -->
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="lblErreur" wrapText="true" style="-fx-font-weight:bold;"/>
        </HBox>

    </VBox>
</VBox>
